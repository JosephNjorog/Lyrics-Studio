DEBUG=false

# Whisper model: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=base
# Device: cpu | cuda
WHISPER_DEVICE=cpu
# Compute type: int8 | float16 | float32
WHISPER_COMPUTE_TYPE=int8

# Callback back to Next.js
CALLBACK_URL=http://localhost:3000/api/webhooks/alignment
CALLBACK_SECRET=replace-with-random-secret

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
