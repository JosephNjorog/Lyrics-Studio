# ─── Next.js App ─────────────────────────────────────────────────────────────

# Neon PostgreSQL (serverless)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary (cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Redis / BullMQ (local dev: redis://localhost:6379)
REDIS_URL="redis://localhost:6379"

# OpenAI (for lyric fetching + translation)
OPENAI_API_KEY=""

# Genius API (genius.com/api-clients)
GENIUS_API_TOKEN=""

# Python alignment microservice
ALIGNMENT_SERVICE_URL="http://localhost:8000"
ALIGNMENT_WEBHOOK_SECRET="replace-with-random-secret"

# ─── Python Alignment Service ─────────────────────────────────────────────────

# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL="base"
# Device: cpu | cuda
WHISPER_DEVICE="cpu"
# Compute type: int8 | float16 | float32
WHISPER_COMPUTE_TYPE="int8"

# Callback back to Next.js API
CALLBACK_URL="http://localhost:3000/api/webhooks/alignment"
CALLBACK_SECRET="replace-with-random-secret"
